  const p = pacingRegistry.get(id);
  if (!p) {
    throw new Error(
      `Pacing preset not found: "${id}". Registered: [${getAllPacingIds().join(", ")}]`,
    );
  }
  return p.value;
}

export function getAllPacingIds(): string[] {
  return Array.from(pacingRegistry.keys());
