                            <span className="muted">—</span>
                          )}
                        </div>
                      </div>
                    </div>
                  )}

                  {showRawJson ? (
                    <details style={{ marginTop: 10 }}>
                      <summary className="muted">
                        Raw role diagnostics JSON
                      </summary>
                      <pre
                        className="maze-ascii-pre"
                        style={{ marginTop: 8, maxHeight: 260 }}
                      >
                        {JSON.stringify(diagnostics, null, 2)}
                      </pre>
                    </details>
                  ) : null}
                </>
              )}
            </div>
          </div>
        </>
      )}
    </div>
  );
}
