button,
input {
    font-family: inherit;
}

.maze-app {
    display: grid;
    grid-template-columns: 420px 1fr;
    gap: 14px;
    padding: 14px;
    min-height: 100vh;
}

/* ---------- Left: Controls ---------- */

.maze-controls {
    background: linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.05),
        rgba(255, 255, 255, 0.02)
    );
    border: 1px solid var(--border);
    border-radius: var(--radius2);
    box-shadow: var(--shadow);
    padding: 14px;
    overflow: auto;
}

.maze-header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 10px;
}

.maze-title {
    margin: 0;
    font-size: 16px;
    letter-spacing: 0.2px;
}

.maze-controls-row {
    display: flex;
    gap: 10px;
    margin-bottom: 12px;
}

.maze-btn {
    appearance: none;
    border: 1px solid var(--border2);
    background: rgba(255, 255, 255, 0.06);
    color: var(--text);
    padding: 9px 10px;
    border-radius: 12px;
    cursor: pointer;
    font-weight: 600;
    transition:
        transform 120ms ease,
        background 120ms ease,
        border-color 120ms ease;
}

.maze-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.18);
    transform: translateY(-1px);
}

.maze-btn:active {
    transform: translateY(0px);
}

.maze-btn:disabled {
    opacity: 0.45;
    cursor: not-allowed;
    transform: none;
}

.maze-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-bottom: 10px;
}

.maze-field {
    display: grid;
    gap: 6px;
}

.maze-field span {
    font-size: 12px;
    color: var(--muted);
}

.maze-field input[type="number"],
.maze-field input[type="text"],
.maze-field input:not([type]) {
    width: 100%;
    padding: 9px 10px;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: rgba(0, 0, 0, 0.18);
    color: var(--text);
    outline: none;
}

.maze-field input:focus {
    border-color: rgba(125, 211, 252, 0.35);
    box-shadow: 0 0 0 3px rgba(125, 211, 252, 0.12);
}

.maze-field--seed {
    grid-column: 1 / -1;
}

.maze-seed-row {
    display: grid;
    grid-template-columns: 1fr 38px;
    gap: 8px;
    align-items: center;
}

.maze-seed-row button {
    width: 38px;
    height: 38px;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.06);
    color: var(--text);
    cursor: pointer;
    transition:
        background 120ms ease,
        transform 120ms ease;
}

.maze-seed-row button:hover {
    background: rgba(255, 255, 255, 0.1);
    transform: translateY(-1px);
}

.maze-checkbox {
    grid-column: 1 / -1;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 10px;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.04);
}

.maze-checkbox span {
    color: var(--muted);
    font-size: 13px;
}

.maze-summary {
    cursor: pointer;
    padding: 8px 10px;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.04);
    color: var(--text);
    font-weight: 700;
    margin-bottom: 10px;
    user-select: none;
}

details {
    margin-bottom: 10px;
}

details[open] > .maze-summary {
    border-color: rgba(125, 211, 252, 0.22);
}

/* ---------- Stats / ASCII ---------- */

.maze-stats {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: rgba(0, 0, 0, 0.15);
    padding: 10px;
}

.maze-stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px 10px;
    font-size: 13px;
    color: var(--muted);
}

.maze-stats-grid b {
    color: var(--text);
}

.maze-ascii-pre {
    margin: 0;
    padding: 10px;
    background: rgba(0, 0, 0, 0.2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    max-height: 300px;
    overflow: auto;
    font-family: var(--mono);
    font-size: 11px;
    line-height: 1.25;
    color: rgba(255, 255, 255, 0.75);
}

/* ---------- Generic panel + circuits ---------- */

.panel {
    margin-top: 12px;
    border: 1px solid var(--border);
    border-radius: var(--radius2);
    background: rgba(0, 0, 0, 0.16);
    padding: 10px;
}

.panelTitle {
    font-weight: 800;
    font-size: 13px;
    margin-bottom: 8px;
    color: var(--text);
}

.muted {
    color: var(--muted);
}

.mono {
    font-family: var(--mono);
}

.circuitsList {
    display: grid;
    gap: 10px;
}

.circuitCard {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.04);
    padding: 10px;
}

.circuitHeader {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 8px;
}

.circuitRow {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: 8px;
    padding: 6px 0;
    border-top: 1px dashed rgba(255, 255, 255, 0.1);
}

.circuitRow:first-of-type {
    border-top: none;
}

.circuitLabel {
    color: var(--muted2);
    font-size: 12px;
    font-weight: 700;
}

.circuitItems {
    color: rgba(255, 255, 255, 0.78);
    font-size: 12px;
    overflow-wrap: anywhere;
}

/* ---------- Right: Preview ---------- */

.maze-preview {
    background: linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.04),
        rgba(255, 255, 255, 0.02)
    );
    border: 1px solid var(--border);
    border-radius: var(--radius2);
    box-shadow: var(--shadow);
    overflow: hidden;
    display: grid;
    grid-template-rows: auto 1fr auto;
}

.maze-preview-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 12px;
    border-bottom: 1px solid var(--border);
    background: rgba(0, 0, 0, 0.12);
}

.maze-tabs {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
}

.maze-tab {
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.04);
    color: rgba(255, 255, 255, 0.8);
    padding: 7px 10px;
    border-radius: 999px;
    cursor: pointer;
    font-weight: 700;
    font-size: 12px;
    transition:
        background 120ms ease,
        border-color 120ms ease,
        transform 120ms ease;
}

.maze-tab:hover {
    background: rgba(255, 255, 255, 0.08);
    transform: translateY(-1px);
}

.maze-tab--active {
    border-color: rgba(125, 211, 252, 0.4);
    background: rgba(125, 211, 252, 0.13);
    color: rgba(255, 255, 255, 0.95);
}

.maze-scale {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--muted);
    font-size: 12px;
    user-select: none;
}

.maze-scale input[type="range"] {
    width: 150px;
}

.maze-scale-value {
    min-width: 34px;
    text-align: right;
    color: rgba(255, 255, 255, 0.8);
    font-weight: 700;
}

/* Canvas panel: IMPORTANT: padding must match your JS (-12px) math */
.maze-canvas-panel {
    position: relative;
    padding: 12px; /* MUST remain 12px unless you change getCellFromMouseEvent */
    overflow: auto;
    background: rgba(0, 0, 0, 0.18);
}

.maze-canvas {
    image-rendering: pixelated;
    image-rendering: crisp-edges;
    background: rgba(0, 0, 0, 0.25);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    display: block;
}

/* Tooltip uses screen coords, so we keep it fixed to viewport */
.maze-tooltip {
    position: fixed;
    z-index: 9999;
    pointer-events: none;
    min-width: 220px;
    max-width: 340px;
    padding: 10px 10px;
    border-radius: 14px;
    border: 1px solid rgba(255, 255, 255, 0.16);
    background: rgba(10, 14, 22, 0.92);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(8px);
}

.maze-tooltip-line {
    font-size: 12px;
    line-height: 1.35;
    color: rgba(255, 255, 255, 0.86);
    font-family: var(--mono);
}

/* Legend */
.maze-legend {
    display: grid;
    gap: 6px;
    padding: 10px 12px;
    border-top: 1px solid var(--border);
    background: rgba(0, 0, 0, 0.12);
    color: var(--muted);
    font-size: 12px;
}

.maze-legend b {
    color: rgba(255, 255, 255, 0.85);
}

/* ---------- Responsive ---------- */

@media (max-width: 1100px) {
    .maze-app {
        grid-template-columns: 1fr;
    }
    .maze-controls {
        order: 2;
    }
    .maze-preview {
        order: 1;
        min-height: 60vh;
    }
}
</file>

